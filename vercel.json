{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "api/info.py",    "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/info",    "dest": "/api/info.py"    },
    { "src": "/(.*)",        "dest": "/api/webhook.py" }
  ]
}
